(define (forth commands)
  (print commands))

(define (split s)
  (def rls (.\ (cs) (list->string (reverse cs))))
  (letn loop ((cs (string->list s))
             (w '())
             (ws '()))
    (cond
      ((null? cs)
       (reverse (cons (rls w) ws)))
      ((|| (= (car cs) (char " ")) (= (car cs) nl))
       (loop (cdr cs)
             '()
             (if (pair? w) (cons (rls w) ws) ws)))
      (else
        (loop (cdr cs)
              (cons (car cs) w)
              ws)))))

(define program
  "2 2 +
  3 5 *")

(split program)
