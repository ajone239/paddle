(def (fun args body) (list 'def args body))

(def (unless cond body)
 (list 'if (list 'not cond) body '()))

(def (when cond body)
 (list 'if cond body '()))

(def (safe-div x y)
    (eval
    (unless '(= y 0) '(/ x y))))

(define else #t)
(define (dumb_cond pairs...)
  (define (dumb_cond2 pairs)
    (if (null? pairs)
      '()
      (list 'if (car (car pairs))
            (cadr (car pairs))
            (dumb_cond2 (cdr pairs)))))
  (dumb_cond2 pairs...))

(def (f x)
 (eval (dumb_cond
        '((= x 1) (* x 3))
        '((= x 2) (+ x 4))
        '(else 33))))
