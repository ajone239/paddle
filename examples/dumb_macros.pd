(def fun (lambda (args body)
          (define fname (car args))
          (define fargs (cdr args))
          (list 'def args body)))

    (eval (fun '(test x y) '(+ x 1)))

(def (unless cond body)
 (list 'if (list 'not cond) body '()))

(define (cond pairs)
 (if (<= (len pairs) 2)
  (list 'if (car pairs) (cdr pairs) '())
  (list 'if (car (car pairs))
   (cdr (car pairs))
   (cond (cdr pairs)))))

(def (f x)
 (eval (cond
  '(((= x 1) (* x 3))
      ((= x 2) (+ x 4))
      (#t 33)))))
