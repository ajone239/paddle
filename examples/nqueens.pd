(define (repeat n xs)
  (letn loop ((n n) (xs xs) (acc '()))
    (if (<= n 0)
      acc
      (loop (- n 1) xs (cons xs acc)))))

(define (board n)
  (repeat n (range n)))

(define (memv v xs)
  (for/or (x xs)
    (= v x)))

(define (eliminate xs val)
  (letn loop ((xs xs) (val val) (i 1))
    (when (pair? xs)
      (let* ((row (car xs))
             (rest (cdr xs))
             (ef (lambda (x) (+ val (* x i))))
             (elims (map ef '(-1 0 1)))
             (ff (lambda (v) (not (memv v elims))))
             (nrow (filter ff row)))
        (cons nrow (loop rest val (+ i 1)))))))

(define (solve board)
  (letn loop ((b board) (sol '()))
    (cond
      ((null? b) sol)
      ((null? (car b)) #f)
      (else (for/or (opt (car b))
              (loop (eliminate (cdr b) opt)
                    (cons opt sol)))))))

(define (reverse xs)
  (foldl cons '() xs))

(reverse (solve (board 8)))
