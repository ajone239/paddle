(define (repeat n xs)
  (define (repeat2 n xs acc)
    (if (<= n 0)
      acc
      (repeat2 (- n 1) xs (cons xs acc))))
  (repeat2 n xs '()))

(define (board n)
  (repeat n (range n)))

(define (memv v xs)
  (for/or (x xs)
    (= v x)))

(define (eliminate xs val)
  (define (elim xs val i)
    (when (pair? xs)
      (progn
        (define row (car xs))
        (define rest (cdr xs))
        (define elims (map (lambda (x) (+ val (* x i))) '(-1 0 1)))
        (define nrow (filter (lambda (v) (not (memv v elims))) row))
        (cons nrow (elim rest val (+ i 1))))))
  (elim xs val 1))

(define (solve board)
  (define (sol2 board sol)
    (cond
      ((null? board) sol)
      ((null? (car board)) #f)
      (else
        (for/or (opt (car board))
          (sol2 (eliminate (cdr board) opt)
                (cons opt sol))))))
  (sol2 board '()))

(solve (board 20))
