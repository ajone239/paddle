(def (map f xs)
     (if (not xs)
       '()
       (cons (f (car xs))
             (map f (cdr xs)))))

(def (filter p xs)
     (if (not xs)
       '()
       (if (p (car xs))
           (cons (car xs) (filter p (cdr xs)))
           (filter p (cdr xs)))))

(def (range n)
     (def (range2 n acc)
          (if (< n 0)
            acc
            (range2 (- n 1) (cons n acc))))
     (range2 (- n 1) '()))

(def (foldl f init xs)
     (if (not (xs))
         init
         (foldl f (f (car xs) init) (cdr xs))))

(def (foldr f init xs)
     (def (fold xs)
          (def xxs (cdr xs))
          (if (not (xxs))
            (car xs)
            (f (car xs) (fold xxs))))
     (f init (fold xs)))

(def (sum xs) (foldl + 0 xs))

(def (reverse xs) (foldl cons '() xs))

(def (length xs)
     (if (not xs)
       0
       (+ 1 (length (cdr xs)))))

(def len length)

(def (> x y) (< y x))
(def (<= x y) (not (< y x)))
(def (>= x y) (not (< x y)))

(def (pow x y)
     (if (< y 1)
       1
       (* x (pow x (- y 1)))))

(def ^ pow)

(def (cadr x) (car (cdr x)))
(def (caddr x) (car (cdr (cdr x))))
(def (cadddr x) (car (cdr (cdr (cdr x)))))

; 10 is the byte value of ascii '\n'
; yes it's hacky but it saved me parser work
(def nl (char 10))
(def (read-line)
  (letn loop ((acc '()))
    (let? ((c (getchar)))
      (if (= c nl)
        (reverse acc)
        (loop (cons c acc))))))
